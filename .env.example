# Supabase 설정값
# Supabase 콘솔 > 프로젝트 설정 > API 에서 복사

# Project URL만 입력 (끝에 /rest/v1 붙이지 마세요)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에입력

# 첨부파일 API용 (Supabase > Project Settings > API > service_role)
# 서버에서만 사용 — 절대 클라이언트에 노출하지 마세요
SUPABASE_SERVICE_ROLE_KEY=

# admin(평가·보고서 메뉴) 이메일 — 쉼표로 여러 명 가능 (선택)
# gujeong@hjcustoms.co.kr 은 코드에 기본 포함됨
NEXT_PUBLIC_CEO_EMAIL=
NEXT_PUBLIC_ADMIN_EMAILS=
